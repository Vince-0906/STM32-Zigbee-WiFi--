     32          static void sda_release(void)   { P1DIR &= (uint8)~OLED_SDA_BM; }
     33          static void scl_release(void)   { P1DIR &= (uint8)~OLED_SCL_BM; }
     34          static void sda_drive_low(void) { P1DIR |= OLED_SDA_BM; }
     35          static void scl_drive_low(void) { P1DIR |= OLED_SCL_BM; }
