    329          
    330          static void on_af_incoming(afIncomingMSGPacket_t *pkt)
    331          {
    332              HalLedSet(HAL_LED_2, HAL_LED_MODE_BLINK);
    333              af_to_zb_report(pkt);
    334          }
    335          
    336          static uint8 role_from_cluster(uint16 cluster)
    337          {
    338              if (cluster == ZCL_CLU_TEMP || cluster == ZCL_CLU_HUM) {
    339                  return ZB_ROLE_TEMP_HUM;
    340              }
    341              if (cluster == ZCL_CLU_LUX) {
    342                  return ZB_ROLE_LUX;
    343              }
    344              return ZB_ROLE_UNKNOWN;
    345          }
    346          
    347          static uint8 device_type_from_capabilities(uint8 cap)
    348          {
    349              return (cap & CAPINFO_DEVICETYPE_FFD) ? ZB_DEV_ROUTER : ZB_DEV_ENDDEV;
    350          }

