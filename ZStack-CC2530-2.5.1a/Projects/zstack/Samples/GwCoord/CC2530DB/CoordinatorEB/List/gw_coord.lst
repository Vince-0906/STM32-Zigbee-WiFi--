    192          
    193          static void on_zdo_state_change(uint8 state)
    194          {
    195              uint16 panid;
    196              uint8 channel;
    197          
    198              panid = _NIB.nwkPanId;
    199              channel = _NIB.nwkLogicalChannel;
    200              zb_net_on_state(state, panid, channel);
    201          
    202              if (state == DEV_ZB_COORD) {
    203                  HalLedSet(HAL_LED_1, HAL_LED_MODE_ON);
    204              }
    205              GwCoord_RefreshLocalDisplay();
    206          }
    207          
    208          static void on_zdo_cb_msg(zdoIncomingMsg_t *inMsg)
    209          {
    210              if (inMsg->clusterID == Device_annce) {
    211                  ZDO_DeviceAnnce_t annce;
    212                  zb_node_t *node;
    213          
    214                  ZDO_ParseDeviceAnnce(inMsg, &annce);
    215                  node = zb_net_touch(annce.nwkAddr, annce.extAddr,
    216                                      device_type_from_capabilities(annce.capabilities), 0);
    217                  if (node != 0) {
    218                      GwCoord_SendNodeInfo(node);
    219                      GwCoord_SendNetStatus();
    220                      GwCoord_RefreshLocalDisplay();
    221                  }
    222              }
    223          }
    224          
    225          static void on_af_data_confirm(afDataConfirm_t *cfm)
    226          {
    227              if (cfm->hdr.status != ZSuccess) {
    228                  GwCoord_SendErr(ERRC_SEND_FAIL, cfm->transID);
    229              }
    230          }
    231          

