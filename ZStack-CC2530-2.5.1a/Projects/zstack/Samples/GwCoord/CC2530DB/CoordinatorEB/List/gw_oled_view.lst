     49          static void line_put_i16_x100(char *buf, uint8 *idx, int16 value)
     50          {
     51              uint16 abs_v;
     52          
     53              if (value < 0) {
     54                  line_putc(buf, idx, '-');
     55                  abs_v = (uint16)(-value);
     56              } else {
     57                  abs_v = (uint16)value;
     58              }
     59          
     60              line_put_u16(buf, idx, (uint16)(abs_v / 100u));
     61              line_putc(buf, idx, '.');
     62              line_putc(buf, idx, (char)('0' + ((abs_v / 10u) % 10u)));
     63              line_putc(buf, idx, (char)('0' + (abs_v % 10u)));
     64          }
     65          
     66          static void line_put_hex16(char *buf, uint8 *idx, uint16 value)
     67          {
     68              uint8 shift;
     69          
     70              for (shift = 0u; shift < 4u; ++shift) {
     71                  uint8 nibble = (uint8)((value >> ((3u - shift) * 4u)) & 0x0Fu);
     72                  line_putc(buf, idx, (char)(nibble < 10u ? ('0' + nibble) : ('A' + nibble - 10u)));
     73              }
     74          }
