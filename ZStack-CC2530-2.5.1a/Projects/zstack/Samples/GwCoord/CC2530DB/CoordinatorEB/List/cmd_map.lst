      4          
      5          #include "cmd_map.h"
      6          #include "gw_coord.h"
      7          #include "zb_net.h"
      8          
      9          static void do_ping(const frame_t *f)
     10          {
     11              (void)f;
     12              (void)GwCoord_SendFrame(CMD_ZB_PING, 0, 0);
     13          }
     14          
     15          static void do_allow_join(const frame_t *f)
     16          {
     17              if (f->plen < 1u) {
     18                  GwCoord_SendErr(ERRC_BAD_FRAME, CMD_ZB_ALLOW_JOIN);
     19                  return;
     20              }
     21              zb_net_allow_join(f->payload[0]);
     22          }
     23          
     24          static void do_list_nodes(const frame_t *f)
     25          {
     26              uint8 i;
     27              uint8 cnt;
     28              const zb_node_t *n;
     29          
     30              (void)f;
     31              cnt = zb_net_count();
     32              for (i = 0; i < cnt; ++i) {
     33                  n = zb_net_at(i);
     34                  if (n != 0) {
     35                      GwCoord_SendNodeInfo(n);
     36                  }
     37              }
     38              if (cnt == 0u) {
     39                  GwCoord_SendNetStatus();
     40              }
     41          }
