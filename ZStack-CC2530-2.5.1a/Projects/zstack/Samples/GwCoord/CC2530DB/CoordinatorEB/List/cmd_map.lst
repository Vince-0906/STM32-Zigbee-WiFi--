      4          
      5          #include "cmd_map.h"
      6          #include "gw_coord.h"
      7          #include "zb_net.h"
      8          
      9          static void do_ping(const frame_t *f)
     10          {
     11              (void)f;
     12              (void)GwCoord_SendFrame(CMD_ZB_PING, 0, 0);
     13          }
     14          
     15          static void do_allow_join(const frame_t *f)
     16          {
     17              if (f->plen < 1u) {
     18                  GwCoord_SendErr(ERRC_BAD_FRAME, CMD_ZB_ALLOW_JOIN);
     19                  return;
     20              }
     21              zb_net_allow_join(f->payload[0]);
     22              GwCoord_SendNetStatus();
     23          }
     24          
     25          static void do_list_nodes(const frame_t *f)
     26          {
     27              uint8 i;
     28              uint8 cnt;
     29              const zb_node_t *n;
     30          
     31              (void)f;
     32              cnt = zb_net_count();
     33              for (i = 0; i < cnt; ++i) {
     34                  n = zb_net_at(i);
     35                  if (n != 0) {
     36                      GwCoord_SendNodeInfo(n);
     37                  }
     38              }
     39              if (cnt == 0u) {
     40                  GwCoord_SendNetStatus();
     41              }
     42          }
     43          

