    231          
    232          static uint8 role_from_cluster(uint16 cluster)
    233          {
    234              if (cluster == ZCL_CLU_TEMP || cluster == ZCL_CLU_HUM) {
    235                  return ZB_ROLE_TEMP_HUM;
    236              }
    237              if (cluster == ZCL_CLU_LUX) {
    238                  return ZB_ROLE_LUX;
    239              }
    240              return ZB_ROLE_UNKNOWN;
    241          }

