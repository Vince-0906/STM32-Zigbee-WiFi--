     36          /* 释放 = 切输入，内部上拉把线拉高 */
     37          static void sda_release(void)   { P1DIR &= (uint8)~OLED_SDA_BM; }
     38          static void scl_release(void)   { P1DIR &= (uint8)~OLED_SCL_BM; }
     39          
     40          /* 驱动低 = 切输出，ODR 位在 init 里已清 0，于是 pin = 0 */
     41          static void sda_drive_low(void) { P1DIR |= OLED_SDA_BM; }
     42          static void scl_drive_low(void) { P1DIR |= OLED_SCL_BM; }
     43          

