     36          static void dht11_input_mode(void)
     37          {
     38              dht11_gpio_mode();
     39              P2DIR &= (uint8)~DHT11_BIT_MASK;
     40          }
     41          
     42          static uint8 dht11_get(void)
     43          {
     44              dht11_gpio_mode();
     45              return (uint8)((P2 & DHT11_BIT_MASK) ? 1u : 0u);
     46          }
