// D:\ZNJJ\ZStack-CC2530-2.5.1a\Projects\zstack\Samples\ZbNode\Source\node_oled_view.c
//    1 /*
//    2  * 节点侧 OLED 视图：将 node_oled_model_t 渲染到 4 行（每行 16 个 8x16 字符）。
//    3  * 不依赖 stdio/printf（IAR-8051 上 sprintf 体积太大且容易栈溢出），手写小整数转字符。
//    4  */
//    5 
//    6 #include "node_oled_view.h"
//    7 #include "oled_ssd1306.h"
//    8 #include "board_e18ms1.h"
//    9 

        RSEG XDATA_Z:XDATA:NOROOT(0)
        DATA8
//   10 static node_oled_model_t s_model;
s_model:
        DS 14
        REQUIRE __INIT_XDATA_Z

        RSEG XDATA_Z:XDATA:NOROOT(0)
        DATA8
//   11 static node_oled_model_t s_last;
s_last:
        DS 14
        REQUIRE __INIT_XDATA_Z

        RSEG XDATA_Z:XDATA:NOROOT(0)
        DATA8
//   12 static uint8             s_initialized = 0;
s_initialized:
        DS 1
        REQUIRE __INIT_XDATA_Z
//   13 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   14 static void line_clear(char *buf)
line_clear:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function line_clear
        CODE
//   15 {
        PUSH    DPL
        CFI DPL0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    DPH
        CFI DPH0 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 0
//   16     uint8 i;
//   17     for (i = 0; i < 16u; ++i) buf[i] = ' ';
        MOV     A,#0x20
        MOV     DPL,R2
        MOV     DPH,R3
        MOV     R0,#0x10
??line_clear_0:
        MOVX    @DPTR,A
        INC     DPTR
        DJNZ    R0,??line_clear_0
//   18     buf[16] = '\0';
        MOV     A,R2
        ADD     A,#0x10
        MOV     DPL,A
        MOV     A,R3
        ADDC    A,#0x0
        MOV     DPH,A
        CLR     A
        MOVX    @DPTR,A
        CFI EndBlock cfiBlock0
//   19 }
        REQUIRE ?Subroutine0
        ; // Fall through to label ?Subroutine0

        RSEG BANKED_CODE:CODE:NOROOT(0)
?Subroutine0:
        CFI Block cfiBlock1 Using cfiCommon0
        CFI NoFunction
        CFI CFA_SP SP+-5
        CFI DPL0 Frame(CFA_SP, 4)
        CFI DPH0 Frame(CFA_SP, 5)
        POP     DPH
        CFI CFA_SP SP+-4
        CFI DPH0 SameValue
        POP     DPL
        CFI CFA_SP SP+-3
        CFI DPL0 SameValue
        LJMP    ?BRET
        CFI EndBlock cfiBlock1
//   20 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   21 static void put_char(char *buf, uint8 *idx, char c)
put_char:
        CFI Block cfiBlock2 Using cfiCommon0
        CFI Function put_char
        CODE
//   22 {
        MOV     A,#-0x9
        LCALL   ?BANKED_ENTER_XDATA
        CFI DPH0 load(1, XDATA, add(CFA_XSP16, literal(-1)))
        CFI DPL0 load(1, XDATA, add(CFA_XSP16, literal(-2)))
        CFI ?BRET_EXT load(1, XDATA, add(CFA_XSP16, literal(-3)))
        CFI ?RET_HIGH load(1, XDATA, add(CFA_XSP16, literal(-4)))
        CFI ?RET_LOW load(1, XDATA, add(CFA_XSP16, literal(-5)))
        CFI R7 load(1, XDATA, add(CFA_XSP16, literal(-6)))
        CFI V0 load(1, XDATA, add(CFA_XSP16, literal(-7)))
        CFI VB load(1, XDATA, add(CFA_XSP16, literal(-8)))
        CFI R6 load(1, XDATA, add(CFA_XSP16, literal(-9)))
        CFI CFA_SP SP+0
        CFI CFA_XSP16 add(XSP16, 9)
        ; Saved register size: 9
        ; Auto size: 0
//   23     if (*idx < 16u) {
