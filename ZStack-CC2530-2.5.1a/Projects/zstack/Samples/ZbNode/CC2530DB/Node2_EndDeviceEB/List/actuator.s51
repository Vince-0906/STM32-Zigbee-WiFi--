//   15 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   16 static void pin_output(uint8 port, uint8 pin)
pin_output:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function pin_output
        CODE
//   17 {
        PUSH    ?V0 + 0
        CFI V0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    ?V0 + 1
        CFI V1 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 0
//   18     if (port == 0) { P0SEL &= (uint8)~(1 << pin); P0DIR |= (uint8)(1 << pin); }
        MOV     A,R1
        JNZ     ??pin_output_0
        MOV     ?V0 + 0,#0x1
        MOV     ?V0 + 1,#0x0
        MOV     A,R2
        MOV     R0,#?V0 + 0
        LCALL   ?S_SHL
        MOV     R0,?V0 + 0
        MOV     A,R0
        CPL     A
        ANL     0xf3,A
        MOV     A,R0
        ORL     0xfd,A
        SJMP    ??pin_output_1
//   19     else if (port == 1) { P1SEL &= (uint8)~(1 << pin); P1DIR |= (uint8)(1 << pin); }
??pin_output_0:
        MOV     A,#0x1
        XRL     A,R1
        JNZ     ??pin_output_2
        MOV     ?V0 + 0,#0x1
        MOV     ?V0 + 1,#0x0
        MOV     A,R2
        MOV     R0,#?V0 + 0
        LCALL   ?S_SHL
        MOV     R0,?V0 + 0
        MOV     A,R0
        CPL     A
        ANL     0xf4,A
        MOV     A,R0
        ORL     0xfe,A
        SJMP    ??pin_output_1
//   20     else if (port == 2) { P2SEL &= (uint8)~(1 << pin); P2DIR |= (uint8)(1 << pin); }
??pin_output_2:
        MOV     A,#0x2
        XRL     A,R1
        JNZ     ??pin_output_1
        MOV     ?V0 + 0,#0x1
        MOV     ?V0 + 1,#0x0
        MOV     A,R2
        MOV     R0,#?V0 + 0
        LCALL   ?S_SHL
        MOV     R0,?V0 + 0
        MOV     A,R0
        CPL     A
        ANL     0xf5,A
        MOV     A,R0
        ORL     0xff,A
        CFI EndBlock cfiBlock0
//   21 }
??pin_output_1:
        REQUIRE ?Subroutine1
        REQUIRE P0SEL
        REQUIRE P0DIR
        REQUIRE P1SEL
        REQUIRE P1DIR
        REQUIRE P2SEL
        REQUIRE P2DIR
        ; // Fall through to label ?Subroutine1

        RSEG BANKED_CODE:CODE:NOROOT(0)
?Subroutine1:
        CFI Block cfiBlock1 Using cfiCommon0
        CFI NoFunction
        CFI CFA_SP SP+-5
        CFI V0 Frame(CFA_SP, 4)
        CFI V1 Frame(CFA_SP, 5)
        POP     ?V0 + 1
        CFI CFA_SP SP+-4
        CFI V1 SameValue
        POP     ?V0 + 0
        CFI CFA_SP SP+-3
        CFI V0 SameValue
        LJMP    ?BRET
        CFI EndBlock cfiBlock1
//   22 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   23 static void pin_write(uint8 port, uint8 pin, uint8 v)
pin_write:
        CFI Block cfiBlock2 Using cfiCommon0
        CFI Function pin_write
        CODE
//   24 {
        PUSH    ?V0 + 0
        CFI V0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    ?V0 + 1
        CFI V1 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 0
//   25     uint8 m = (uint8)(1 << pin);
        MOV     ?V0 + 0,#0x1
        MOV     ?V0 + 1,#0x0
        MOV     A,R2
        MOV     R0,#?V0 + 0
        LCALL   ?S_SHL
        MOV     R0,?V0 + 0
//   26     if (port == 0) { if (v) P0 |= m; else P0 &= (uint8)~m; }
        MOV     A,R1
        JNZ     ??pin_write_0
        MOV     A,R3
        JZ      ??pin_write_1
        MOV     A,R0
        ORL     0x80,A
        SJMP    ??pin_write_2
??pin_write_1:
        MOV     A,R0
        CPL     A
        ANL     0x80,A
        SJMP    ??pin_write_2
//   27     else if (port == 1) { if (v) P1 |= m; else P1 &= (uint8)~m; }
??pin_write_0:
        MOV     A,#0x1
        XRL     A,R1
        JNZ     ??pin_write_3
        MOV     A,R3
        JZ      ??pin_write_4
        MOV     A,R0
        ORL     0x90,A
        SJMP    ??pin_write_2
??pin_write_4:
        MOV     A,R0
        CPL     A
        ANL     0x90,A
        SJMP    ??pin_write_2
//   28     else if (port == 2) { if (v) P2 |= m; else P2 &= (uint8)~m; }
??pin_write_3:
        MOV     A,#0x2
        XRL     A,R1
        JNZ     ??pin_write_2
        MOV     A,R3
        JZ      ??pin_write_5
        MOV     A,R0
