     53          static void put_hex16(char *buf, uint8 *idx, uint16 value)
     54          {
     55              uint8 shift;
     56              for (shift = 0u; shift < 4u; ++shift) {
     57                  uint8 nibble = (uint8)((value >> ((3u - shift) * 4u)) & 0x0Fu);
     58                  put_char(buf, idx, (char)(nibble < 10u ? ('0' + nibble) : ('A' + nibble - 10u)));
     59              }
     60          }
     61          
     62          static void put_temp_x100(char *buf, uint8 *idx, int16 value)
     63          {
     64              uint16 abs_v;
     65          
     66              if (value < 0) {
     67                  put_char(buf, idx, '-');
     68                  abs_v = (uint16)(-value);
     69              } else {
     70                  abs_v = (uint16)value;
     71              }
     72              put_u16(buf, idx, (uint16)(abs_v / 100u));
     73              put_char(buf, idx, '.');
     74              put_char(buf, idx, (char)('0' + ((abs_v / 10u) % 10u)));
     75              put_char(buf, idx, (char)('0' + (abs_v % 10u)));
     76          }
