    129          
    130          static uint8 model_changed(void)
    131          {
    132              /* 简单 memcmp 替代：逐字段判等，避免拉进 string.h 依赖 */
    133              if (s_model.role        != s_last.role)        return 1u;
    134              if (s_model.online      != s_last.online)      return 1u;
    135              if (s_model.short_addr  != s_last.short_addr)  return 1u;
    136              if (s_model.channel     != s_last.channel)     return 1u;
    137              if (s_model.temp_x100   != s_last.temp_x100)   return 1u;
    138              if (s_model.hum_x100    != s_last.hum_x100)    return 1u;
    139              if (s_model.lux         != s_last.lux)         return 1u;
    140              if (s_model.led_on      != s_last.led_on)      return 1u;
    141              if (s_model.buzzer_on   != s_last.buzzer_on)   return 1u;
    142              if (s_model.has_sample  != s_last.has_sample)  return 1u;
    143              return 0u;
    144          }
