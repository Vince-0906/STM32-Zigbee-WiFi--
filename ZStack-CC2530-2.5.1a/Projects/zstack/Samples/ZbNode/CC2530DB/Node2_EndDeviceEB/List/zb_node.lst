    358          static void on_data_confirm(afDataConfirm_t *cfm)
    359          {
    360              if (s_report_diag.pending_reports > 0) {
    361                  s_report_diag.pending_reports--;
    362              }
    363          
    364              s_report_diag.last_status = cfm->hdr.status;
    365              s_report_diag.last_transid = cfm->transID;
    366              if (cfm->hdr.status == ZSuccess) {
    367                  s_report_diag.last_result = 0;
    368                  s_report_diag.consecutive_fail = 0;
    369                  if (s_wait_first_report_cfm && s_nwk_joined) {
    370                      s_wait_first_report_cfm = 0u;
    371                      s_link_ready = 1u;
    372                      status_led_refresh();
    373                  }
    374              } else {
    375                  note_local_report_failure((int8)cfm->hdr.status);
    376              }
    377          }
    378          

