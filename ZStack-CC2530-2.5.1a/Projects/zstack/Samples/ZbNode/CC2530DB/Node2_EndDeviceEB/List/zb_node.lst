    218              if (s_report_diag.pending_reports > 0) {
    219                  s_report_diag.pending_reports--;
    220              }
    221          
    222              s_report_diag.last_status = cfm->hdr.status;
    223              s_report_diag.last_transid = cfm->transID;
    224              if (cfm->hdr.status == ZSuccess) {
    225                  s_report_diag.last_result = 0;
    226                  s_report_diag.consecutive_fail = 0;
    227              } else {
    228                  note_local_report_failure((int8)cfm->hdr.status);
    229              }
    230          }
