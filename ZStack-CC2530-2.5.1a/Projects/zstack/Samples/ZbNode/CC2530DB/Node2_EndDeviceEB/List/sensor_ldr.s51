// D:\ZNJJ\ZStack-CC2530-2.5.1a\Projects\zstack\Samples\ZbNode\Source\sensor_ldr.c
//    1 /*
//    2  * 光敏 ADC 采样（AIN7 = P0.7，E18-MS1 板内部分压节点）。
//    3  * 返回值 uint16 lux 估算：ADC code → 3.3V 参考下的近似换算，非精确。
//    4  */
//    5 
//    6 #include "sensor_ldr.h"
//    7 #include "board_e18ms1.h"
//    8 #include "ioCC2530.h"

        ASEGN SFR_AN:DATA:NOROOT,0f2H
// unsigned char volatile __sfr APCFG
APCFG:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0f3H
// unsigned char volatile __sfr P0SEL
P0SEL:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0fdH
// unsigned char volatile __sfr P0DIR
P0DIR:
        DATA8
        DS 1
//    9 #include "hal_adc.h"
//   10 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   11 void ldr_init(void)
ldr_init:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function ldr_init
        CODE
//   12 {
        ; Saved register size: 0
        ; Auto size: 0
//   13     /* P0.7 设为外设模式（ADC 由 ADCCON 配置通道即可占管） */
//   14     P0SEL |= (uint8)(1 << NODE_LDR_ADC_CH);
        ORL     0xf3,#0x80
//   15     P0DIR &= (uint8)~(1 << NODE_LDR_ADC_CH);
        ANL     0xfd,#0x7f
//   16     APCFG |= (uint8)(1 << NODE_LDR_ADC_CH);
        ORL     0xf2,#0x80
//   17 }
        LJMP    ?BRET
        CFI EndBlock cfiBlock0
        REQUIRE P0SEL
        REQUIRE P0DIR
        REQUIRE APCFG
//   18 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   19 uint16 ldr_read_lux(void)
ldr_read_lux:
