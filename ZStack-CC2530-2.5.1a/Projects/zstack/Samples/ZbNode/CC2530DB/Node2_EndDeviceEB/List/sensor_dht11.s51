// D:\ZNJJ\ZStack-CC2530-2.5.1a\Projects\zstack\Samples\ZbNode\Source\sensor_dht11.c
//    1 /*
//    2  * DHT11 单总线驱动（P2.0，10k 上拉）。
//    3  * 时序：主机拉低 ≥18ms → 释放总线 20~40us → 读 40-bit 数据。
//    4  * 禁浮点：温度取 i16 *100（°C*100），湿度 u16 *100 (%*100)。
//    5  */
//    6 
//    7 #include "sensor_dht11.h"
//    8 #include "board_e18ms1.h"
//    9 #include "ioCC2530.h"

        ASEGN SFR_AN:DATA:NOROOT,0a0H
// union <unnamed> volatile __sfr _A_P2
_A_P2:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0f5H
// unsigned char volatile __sfr P2SEL
P2SEL:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0ffH
// unsigned char volatile __sfr P2DIR
P2DIR:
        DATA8
        DS 1
//   10 #include "OnBoard.h"
//   11 
//   12 #define DHT11_BIT_MASK  (uint8)(1 << NODE_DHT11_PIN)
//   13 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   14 static void dht11_pin_out(void)  { P2SEL &= (uint8)~DHT11_BIT_MASK; P2DIR |= DHT11_BIT_MASK; }
dht11_pin_out:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function dht11_pin_out
        CODE
        ; Saved register size: 0
        ; Auto size: 0
        ANL     0xf5,#0xfe
        ORL     0xff,#0x1
        LJMP    ?BRET
        CFI EndBlock cfiBlock0
        REQUIRE P2SEL
        REQUIRE P2DIR
//   15 static void dht11_pin_in(void)   { P2SEL &= (uint8)~DHT11_BIT_MASK; P2DIR &= (uint8)~DHT11_BIT_MASK; }

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   16 static void dht11_set(uint8 v)   { if (v) P2 |= DHT11_BIT_MASK; else P2 &= (uint8)~DHT11_BIT_MASK; }
dht11_set:
        CFI Block cfiBlock1 Using cfiCommon0
        CFI Function dht11_set
        CODE
        ; Saved register size: 0
        ; Auto size: 0
        MOV     A,R1
        JZ      ??dht11_set_0
        SETB    0xa0.0
        SJMP    ??dht11_set_1
??dht11_set_0:
        CLR     0xa0.0
??dht11_set_1:
        LJMP    ?BRET
        CFI EndBlock cfiBlock1
        REQUIRE _A_P2
//   17 static uint8 dht11_get(void)     { return (uint8)((P2 & DHT11_BIT_MASK) ? 1 : 0); }
//   18 
//   19 /* 在 32 MHz 时钟下用简单 for 循环延时（非精确，但 DHT11 容差大）。 */

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   20 static void delay_us(uint16 us)
delay_us:
        CFI Block cfiBlock2 Using cfiCommon0
        CFI Function delay_us
        CODE
//   21 {
        PUSH    DPL
        CFI DPL0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    DPH
        CFI DPH0 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 2
        MOV     A,#-0x2
        LCALL   ?ALLOC_XSTACK8
        CFI CFA_XSP16 add(XSP16, 2)
//   22     /* 经 32MHz + -Ohigh 经验值：每个 for 迭代 ~1us。上电实测再校准。 */
//   23     volatile uint16 i;
//   24     while (us--) {
??delay_us_0:
        MOV     A,R2
        MOV     R0,A
        MOV     A,R3
        MOV     R1,A
        MOV     A,R0
        ADD     A,#-0x1
        DEC     R2
        MOV     A,R1
        ADDC    A,#-0x1
        MOV     R3,A
        MOV     A,R0
        ORL     A,R1
        JZ      ??delay_us_1
//   25         for (i = 0; i < 8; ++i) { ; }
        MOV     DPL,?XSP + 0
        MOV     DPH,?XSP + 1
        CLR     A
        MOVX    @DPTR,A
        INC     DPTR
??delay_us_2:
        MOVX    @DPTR,A
        MOV     DPL,?XSP + 0
        MOV     DPH,?XSP + 1
        CLR     C
        MOVX    A,@DPTR
        SUBB    A,#0x8
        INC     DPTR
        MOVX    A,@DPTR
        SUBB    A,#0x0
        JNC     ??delay_us_0
        MOV     DPL,?XSP + 0
        MOV     DPH,?XSP + 1
        MOVX    A,@DPTR
        ADD     A,#0x1
        MOVX    @DPTR,A
        INC     DPTR
        MOVX    A,@DPTR
        ADDC    A,#0x0
        SJMP    ??delay_us_2
//   26     }
//   27 }
??delay_us_1:
        MOV     A,#0x2
        LCALL   ?DEALLOC_XSTACK8
        CFI EndBlock cfiBlock2
        REQUIRE ?Subroutine0
        ; // Fall through to label ?Subroutine0

        RSEG BANKED_CODE:CODE:NOROOT(0)
?Subroutine0:
        CFI Block cfiBlock3 Using cfiCommon0
        CFI NoFunction
        CFI CFA_SP SP+-5
        CFI DPL0 Frame(CFA_SP, 4)
        CFI DPH0 Frame(CFA_SP, 5)
        POP     DPH
        CFI CFA_SP SP+-4
        CFI DPH0 SameValue
        POP     DPL
        CFI CFA_SP SP+-3
        CFI DPL0 SameValue
        LJMP    ?BRET
        CFI EndBlock cfiBlock3
