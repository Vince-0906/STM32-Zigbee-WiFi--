     48          static const char *state_name(devStates_t st)
     49          {
     50              switch (st) {
     51              case DEV_HOLD:               return "HOLD";
     52              case DEV_INIT:               return "INIT";
     53              case DEV_NWK_DISC:           return "NWK_DISC";
     54              case DEV_NWK_JOINING:        return "NWK_JOINING";
     55              case DEV_NWK_REJOIN:         return "NWK_REJOIN";
     56              case DEV_END_DEVICE_UNAUTH:  return "END_UNAUTH";
     57              case DEV_END_DEVICE:         return "END_DEVICE";
     58              case DEV_ROUTER:             return "ROUTER";
     59              case DEV_COORD_STARTING:     return "COORD_START";
     60              case DEV_ZB_COORD:           return "ZB_COORD";
     61              case DEV_NWK_ORPHAN:         return "NWK_ORPHAN";
     62              default:                     return "?";
     63              }
