//    1 /*
//    2  * E18-MS1 板载 OLED 软件 I2C：与 GwCoord 侧 soft_i2c.c 完全同源。
//    3  * cc2530_board.md §4.8 / 原理图 U10：
//    4  *   U10.3 = SCL → P1.2  → OLED_SCL_BM = 0x04
//    5  *   U10.4 = SDA → P1.3  → OLED_SDA_BM = 0x08
//    6  */
//    7 
//    8 #include "soft_i2c.h"
//    9 
//   10 #include "ioCC2530.h"

        ASEGN SFR_AN:DATA:NOROOT,090H
// union <unnamed> volatile __sfr _A_P1
_A_P1:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0f4H
// unsigned char volatile __sfr P1SEL
P1SEL:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0f7H
// unsigned char volatile __sfr P2INP
P2INP:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0feH
// unsigned char volatile __sfr P1DIR
P1DIR:
        DATA8
        DS 1
//   11 #include "OnBoard.h"
//   12 
//   13 #define OLED_SCL_BM  ((uint8)0x04u)   /* P1.2 */
//   14 #define OLED_SDA_BM  ((uint8)0x08u)   /* P1.3 */
//   15 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   16 static void i2c_delay(void)
i2c_delay:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function i2c_delay
        CODE
//   17 {
        PUSH    DPL
        CFI DPL0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    DPH
        CFI DPH0 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 1
        MOV     A,#-0x1
        LCALL   ?ALLOC_XSTACK8
        CFI CFA_XSP16 add(XSP16, 1)
//   18     volatile uint8 i;
//   19     for (i = 0; i < 20u; ++i) {
        MOV     DPL,?XSP + 0
        MOV     DPH,?XSP + 1
        CLR     A
        SJMP    ??i2c_delay_0
//   20         asm("NOP");
??i2c_delay_1:
        NOP
//   21     }
        MOVX    A,@DPTR
        INC     A
??i2c_delay_0:
        MOVX    @DPTR,A
        MOVX    A,@DPTR
        CLR     C
        SUBB    A,#0x14
        JC      ??i2c_delay_1
//   22 }
        MOV     A,#0x1
        LCALL   ?DEALLOC_XSTACK8
        CFI CFA_XSP16 XSP16+0
        SJMP    ??Subroutine5_0
        CFI EndBlock cfiBlock0

        RSEG BANKED_CODE:CODE:NOROOT(0)
?Subroutine0:
        CFI Block cfiBlock1 Using cfiCommon0
        CFI NoFunction
        CFI CFA_SP SP+-5
        CFI DPL0 Frame(CFA_SP, 4)
        CFI DPH0 Frame(CFA_SP, 5)
        LCALL   ??i2c_delay?relay
        CFI EndBlock cfiBlock1
        REQUIRE ??Subroutine5_0
        ; // Fall through to label ??Subroutine5_0

        RSEG BANKED_CODE:CODE:NOROOT(0)
??Subroutine5_0:
        CFI Block cfiBlock2 Using cfiCommon0
        CFI NoFunction
        CFI CFA_SP SP+-5
        CFI DPL0 Frame(CFA_SP, 4)
        CFI DPH0 Frame(CFA_SP, 5)
        POP     DPH
        CFI CFA_SP SP+-4
        CFI DPH0 SameValue
        POP     DPL
        CFI CFA_SP SP+-3
        CFI DPL0 SameValue
        LJMP    ?BRET
        CFI EndBlock cfiBlock2
//   23 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   24 static void sda_set(uint8 high)
sda_set:
        CFI Block cfiBlock3 Using cfiCommon0
        CFI Function sda_set
        CODE
//   25 {
        ; Saved register size: 0
        ; Auto size: 0
//   26     if (high) {
        MOV     A,R1
        JZ      ??sda_set_0
//   27         P1 |= OLED_SDA_BM;
        SETB    0x90.3
        SJMP    ??sda_set_1
//   28     } else {
//   29         P1 &= (uint8)~OLED_SDA_BM;
??sda_set_0:
        CLR     0x90.3
//   30     }
//   31 }
??sda_set_1:
        LJMP    ?BRET
        CFI EndBlock cfiBlock3
        REQUIRE _A_P1
//   32 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   33 static void scl_set(uint8 high)
scl_set:
        CFI Block cfiBlock4 Using cfiCommon0
        CFI Function scl_set
        CODE
//   34 {
        ; Saved register size: 0
        ; Auto size: 0
//   35     if (high) {
        MOV     A,R1
        JZ      ??scl_set_0
//   36         P1 |= OLED_SCL_BM;
        SETB    0x90.2
        SJMP    ??scl_set_1
//   37     } else {
//   38         P1 &= (uint8)~OLED_SCL_BM;
??scl_set_0:
        CLR     0x90.2
//   39     }
//   40 }
??scl_set_1:
        LJMP    ?BRET
        CFI EndBlock cfiBlock4
        REQUIRE _A_P1
//   41 

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   42 void soft_i2c_init(void)
soft_i2c_init:
        CFI Block cfiBlock5 Using cfiCommon0
        CFI Function soft_i2c_init
        CODE
//   43 {
        FUNCALL soft_i2c_init, sda_set
        LOCFRAME ISTACK, 2, STACK
